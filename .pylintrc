# Configuración de Pylint para la API de Tareas.

[MAIN]
ignore = .venv

[MESSAGES CONTROL]
# unused-argument: los manejadores de @app.errorhandler reciben 'error'
#   aunque no lo usen (parte del contrato de Flask).
# too-few-public-methods: la API usa funciones-vista, no clases.
# global-statement: 'tasks' es estado en memoria compartido a propósito.
disable =
    unused-argument,
    too-few-public-methods,
    global-statement

[FORMAT]
# Longitud de línea alineada con Black (88 columnas).
max-line-length = 88

[BASIC]
# Permite nombres cortos idiomáticos para variables locales.
good-names = id, t, fn, db

[DESIGN]
# Fuerza vistas concisas limitando las variables locales.
max-locals = 10
