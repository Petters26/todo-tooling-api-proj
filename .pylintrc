# Pylint configuration for the Tasks API.

[MAIN]
ignore = .venv

[MESSAGES CONTROL]
# unused-argument: @app.errorhandler handlers receive 'error'
#   even if they do not use it (part of Flask's contract).
# too-few-public-methods: the API uses view functions, not classes.
# global-statement: 'tasks' is in-memory shared state on purpose.
disable =
    unused-argument,
    too-few-public-methods,
    global-statement

[FORMAT]
# Line length aligned with Black (88 columns).
max-line-length = 88

[BASIC]
# Allows short idiomatic names for local variables.
good-names = id, t, fn, db

[DESIGN]
# Forces concise views by limiting local variables.
max-locals = 10
